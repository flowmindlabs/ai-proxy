# Your Anthropic API key — get it from https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Optional: Protect your proxy with a password.
# Anyone connecting to your proxy must send this as their API key.
# Leave blank to disable auth (fine for local-only use).
PROXY_API_KEY=

# Optional: Change the port (default 3030)
# PORT=3030
