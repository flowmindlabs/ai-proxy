# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key — get it from https://console.anthropic.com
# IMPORTANT: You must also add credits at https://console.anthropic.com/settings/billing
# Without credits you will get a "Your credit balance is too low" error.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional ──────────────────────────────────────────────────────────────────

# Your OpenAI API key — only needed if you want gpt-* models to route to OpenAI
# If not set, gpt-* model names are automatically mapped to the closest Claude model
# OPENAI_API_KEY=

# Protect your proxy with a password (recommended if running on a server)
# Anyone connecting must send this as their API key
# Leave blank to disable auth (fine for local-only use)
# PROXY_API_KEY=

# Port to run the proxy on (default 3030)
# PORT=3030

# Rate limit per IP per minute (default 60, set to 0 to disable)
# RATE_LIMIT_PER_MIN=60

# CORS origin — who can call the proxy from a browser (default * allows all)
# Tighten this if you expose the proxy on a public server
# CORS_ORIGIN=*
