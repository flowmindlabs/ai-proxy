# ── Required ──────────────────────────────────────────────────────────────────

# Your Anthropic API key — get it from https://platform.claude.com
# IMPORTANT: You must also add credits at https://platform.claude.com under Billing
# Without credits you will get a "Your credit balance is too low" error.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ── Optional ──────────────────────────────────────────────────────────────────

# Your OpenAI API key — only needed if you want gpt-* models to route to OpenAI directly.
# If not set and someone sends a gpt-* model name, they will get a clear error message.
# OPENAI_API_KEY=

# ── PROXY_API_KEY — Password protection for your proxy ────────────────────────
#
# What it does:
#   Adds a password layer so only people who know this key can use your proxy.
#   Anyone trying to connect must send this value as their API key in their tool.
#
# When to use it:
#   - Running on a server (e.g. deployed online) → ALWAYS set this
#   - Sharing with teammates over a network       → ALWAYS set this
#   - Running locally for yourself only           → Safe to leave blank
#
# How it works:
#   Your real API key (Anthropic/OpenAI) is never exposed to anyone.
#   You give community members this PROXY_API_KEY as their "API key" in their tool.
#   They can use the proxy but never see your real credentials.
#
# Example: PROXY_API_KEY=my-secret-community-password
# PROXY_API_KEY=

# ── CORS_ORIGIN — Control which websites can call your proxy ──────────────────
#
# What it does:
#   CORS (Cross-Origin Resource Sharing) controls which websites/apps running
#   in a browser are allowed to send requests to your proxy.
#
# When to use it:
#   - Running locally for yourself       → Leave as * (allow all), no risk
#   - Exposed on a public server         → Set to your specific website URL
#   - Shared with a team on a server     → Set to your team's app URL
#
# Examples:
#   CORS_ORIGIN=*                        → Allow any website (default, fine for local)
#   CORS_ORIGIN=https://myapp.com        → Only allow your specific app
#   CORS_ORIGIN=http://localhost:5173    → Only allow a local frontend (e.g. Vite dev server)
#
# Note: This only affects browser-based tools. CLI tools (Claude Code, curl) are not affected.
# CORS_ORIGIN=*

# Port to run the proxy on (default 3030)
# PORT=3030

# Rate limit per IP per minute (default 60, set to 0 to disable)
# Prevents abuse if someone has your PROXY_API_KEY and hammers the proxy
# RATE_LIMIT_PER_MIN=60
